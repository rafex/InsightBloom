# ── Comportamiento por defecto ────────────────────────────────────────────────
* text=auto

# ── Shell scripts → LF siempre ───────────────────────────────────────────────
*.sh    text eol=lf
mvnw    text eol=lf
gradlew text eol=lf

# ── Archivos Windows → CRLF siempre ──────────────────────────────────────────
*.cmd   text eol=crlf
*.bat   text eol=crlf
*.ps1   text eol=crlf

# ── Binarios → sin conversión ─────────────────────────────────────────────────
*.jar   binary
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.svg   text eol=lf
*.woff  binary
*.woff2 binary
*.ttf   binary
*.eot   binary
*.zip   binary
*.tar   binary
*.tar.gz binary
